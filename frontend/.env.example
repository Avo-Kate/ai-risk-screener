# Copy this file to .env and fill in your Supabase project values:
#   cp .env.example .env
#
# These are public, client-side values (Vite inlines VITE_* vars into the
# bundle). The anon key is safe to expose; the backend independently verifies
# the signed JWT. Do NOT put the Supabase service-role key or JWT secret here.
#
# Find both under: Supabase dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
