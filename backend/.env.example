# Copy this file to .env and fill in your key:  cp .env.example .env
#
# Your Anthropic API key (required). Get one at https://console.anthropic.com/
# The key is read from the environment and is never hardcoded.
ANTHROPIC_API_KEY=sk-XpAxmsJDYUhWmYe5Tt0-zg

# Optional — the model to use. Defaults to claude-sonnet-4-20250514.
# Newer options if you want to upgrade: claude-sonnet-4-6, claude-opus-4-8
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — max output tokens for an assessment (default 8000).
# ANTHROPIC_MAX_TOKENS=8000

# Optional — SQLite database location (default: backend/ai_risk.db).
# DATABASE_URL=sqlite:///./ai_risk.db

# Optional — comma-separated allowed CORS origins for the frontend.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
