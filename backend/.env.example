# Copy this file to .env and fill in your values:  cp .env.example .env
#
# Your Anthropic API key (required). Get one at https://console.anthropic.com/
# The key is read from the environment and is never hardcoded. Do NOT commit
# your real key — .env is gitignored; this example must stay a placeholder.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — the model to use. Defaults to claude-sonnet-5.
# More capable: claude-opus-4-8. Lower cost: claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional — max output tokens for an assessment (default 8000).
# ANTHROPIC_MAX_TOKENS=8000

# Authentication (required for the assessment routes). Supabase issues and signs
# user JWTs; this backend only verifies them (PyJWT). Pick ONE method:
#
# 1) Recommended — asymmetric (default for current Supabase projects). Set the
#    project URL; tokens (ES256/RS256) are verified against the public JWKS
#    endpoint. No secret needed. Find the URL under Project Settings -> API,
#    or build it as https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
#
# 2) Legacy — symmetric HS256 (older projects / some self-hosted setups). Set the
#    shared secret from Project Settings -> API -> legacy "JWT Secret" instead.
#    Takes precedence over SUPABASE_URL if both are set. Never commit a real secret.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
#
# Optional — the expected token audience (default "authenticated").
# SUPABASE_JWT_AUD=authenticated

# Database — PostgreSQL. Read from DATABASE_URL as a SQLAlchemy + psycopg (v3)
# URL: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
#
# If unset, the app defaults to a local Postgres at:
#   postgresql+psycopg://ai_risk:ai_risk@localhost:5432/ai_risk
#
# Local development (matches the default; see README "Database & migrations"):
# DATABASE_URL=postgresql+psycopg://ai_risk:ai_risk@localhost:5432/ai_risk
#
# Managed Postgres (Neon, Supabase, etc.) — set this in the host's environment
# settings, never in the repo. Keep the +psycopg driver and add sslmode:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional — comma-separated allowed CORS origins for the frontend.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
